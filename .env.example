# Copy this file to .env and fill in your keys.
# None of these cost money — all free tiers.

# --- Gemini (Google AI Studio) -------------------------------------------
# Free tier: 1500 requests/day, 1M tokens/min
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Custom Search JSON API ----------------------------------------
# Free tier: 100 search queries/day
# Step 1 — Create a search engine: https://programmablesearchengine.google.com
#           Set it to search the whole web, copy the "cx" value below
# Step 2 — Enable the API + get key: https://console.cloud.google.com
#           APIs & Services > Custom Search JSON API > Create credentials
GOOGLE_CSE_API_KEY=your_google_cse_api_key_here
GOOGLE_CSE_ID=your_search_engine_cx_id_here

# --- GitHub (optional but recommended) ------------------------------------
# Raises rate limit from 60 to 5000 requests/hour
# Get token: https://github.com/settings/tokens  (no scopes needed)
GITHUB_TOKEN=your_github_token_here
